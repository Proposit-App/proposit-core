{
    "name": "@polintpro/proposit-core",
    "version": "0.5.6",
    "description": "Core engine for building and manipulating propositional logic arguments.",
    "license": "MIT",
    "keywords": [
        "propositional-logic",
        "logic-engine",
        "argument",
        "validation",
        "formal-logic"
    ],
    "homepage": "https://github.com/polintpro/proposit-core",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./extensions/ieee": {
            "types": "./dist/extensions/ieee/index.d.ts",
            "import": "./dist/extensions/ieee/index.js"
        },
        "./extensions/basics": {
            "types": "./dist/extensions/basics/index.d.ts",
            "import": "./dist/extensions/basics/index.js"
        }
    },
    "bin": {
        "proposit-core": "./dist/cli.js"
    },
    "files": [
        "dist",
        "skills"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/polintpro/proposit-core.git"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "generate:parser": "peggy --format es -o src/lib/core/parser/formula-gen.js src/lib/core/parser/formula.peggy",
        "build": "rm -rf dist tsconfig.build.tsbuildinfo && pnpm run generate:parser && pnpm tsc -p tsconfig.build.json && cp src/lib/core/parser/formula-gen.js dist/lib/core/parser/formula-gen.js",
        "typecheck": "pnpm tsc -p tsconfig.json",
        "lint": "pnpm run prettify:check && pnpm eslint .",
        "prettify": "pnpm prettier -w .",
        "prettify:check": "pnpm prettier --check .",
        "test": "pnpm vitest run",
        "check": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
        "cli": "node dist/cli.js",
        "prepublishOnly": "pnpm run check"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.2.3",
        "eslint": "^9.39.2",
        "eslint-plugin-check-file": "^3.3.1",
        "globals": "^16.5.0",
        "peggy": "^5.0.6",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0",
        "vitest": "^4.0.18"
    },
    "packageManager": "pnpm@10.23.0",
    "dependencies": {
        "commander": "^14.0.3",
        "js-yaml": "^4.1.1",
        "typebox": "^1.1.0"
    }
}
